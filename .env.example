# =============================================================================
# Englishphile - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL for production; local SQLite for dev)
# -----------------------------------------------------------------------------
# Local dev: point to SQLite file.
# Production (Neon): use pooled connection URL from Neon dashboard.
#   - Connection Details → Connection string → Pooled
DATABASE_URL="file:./dev.db"

# Neon direct connection for migrations only. Not used at app runtime.
#   - Connection Details → Connection string → Non-pooled (direct)
# Only needed for `prisma migrate` / `prisma db push` / `db:import:portable`.
# On Vercel, DATABASE_URL is used at runtime; DIRECT_URL is used during build.
DIRECT_URL=""

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Long random secret for signed session cookies.
# Generate locally with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Change this to a unique secret before deploying to production.
SESSION_SECRET="replace-with-a-long-random-secret"

# Compatibility fallback (kept from older setup). Prefer SESSION_SECRET.
AUTH_SECRET="replace-with-a-long-random-secret"

# -----------------------------------------------------------------------------
# Site Owner / Admin
# -----------------------------------------------------------------------------
# Email of the site owner/admin. This email can access admin areas after signup.
# Public signup still creates learner accounts only.
OWNER_EMAIL="owner@example.com"

# -----------------------------------------------------------------------------
# Public URLs (set in production)
# -----------------------------------------------------------------------------
# Full URL of the deployed app, without trailing slash.
# Example: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional support email shown on /contact page.
NEXT_PUBLIC_CONTACT_EMAIL=""

# -----------------------------------------------------------------------------
# AI Writing Grader (optional, beta)
# -----------------------------------------------------------------------------
# Server-side API key for the Gemini API. Leave empty to keep the feature
# disabled — the grader page then shows a friendly "not enabled" state.
# NEVER expose this key to the browser (no NEXT_PUBLIC_ prefix).
GEMINI_API_KEY=""

# Optional model override for the writing grader.
GEMINI_MODEL="gemini-3.5-flash"

# -----------------------------------------------------------------------------
# Runtime environment
# -----------------------------------------------------------------------------
# development | production
# Usually set automatically by the platform (Vercel sets this to "production").
NODE_ENV="development"

# =============================================================================
# Englishphile - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Database (isolated PostgreSQL for every environment)
# -----------------------------------------------------------------------------
# Local development must use a separate PostgreSQL database that contains no
# production data. Prefer an independent Neon project or another isolated
# PostgreSQL instance. Never use production DATABASE_URL or DIRECT_URL locally.
#
# Pooled PostgreSQL connection used by the application at runtime.
DATABASE_URL=""

# Direct PostgreSQL connection used for migration and administrative workflows.
# It is optional at application runtime, but required by workflows that need a
# non-pooled connection. Keep it isolated from production in local development.
DIRECT_URL=""

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Long random secret for signed session cookies.
# Generate locally with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Change this to a unique secret before deploying to production.
SESSION_SECRET="replace-with-a-long-random-secret"

# Compatibility fallback (kept from older setup). Prefer SESSION_SECRET.
# Leave empty for new deployments. Set only for legacy compatibility when
# SESSION_SECRET is not available.
AUTH_SECRET=""

# Server-only high-entropy credential for the Production Vercel Cron request.
# Generate at least 32 random bytes; the route accepts 16-512 UTF-8 bytes.
# Never prefix with NEXT_PUBLIC_ and never commit a real value. Vercel sends it
# as Authorization: Bearer <CRON_SECRET>. Production requires its own value;
# Preview/local values used for isolated testing must differ from Production.
CRON_SECRET=""

# -----------------------------------------------------------------------------
# Site Owner / Admin
# -----------------------------------------------------------------------------
# Email of the site owner/admin. This email can access admin areas after signup.
# Public signup still creates learner accounts only.
OWNER_EMAIL="owner@example.com"

# -----------------------------------------------------------------------------
# Public URLs (set in production)
# -----------------------------------------------------------------------------
# Full URL of the deployed app, without trailing slash.
# Example: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional support email shown on /contact page.
NEXT_PUBLIC_CONTACT_EMAIL=""

# -----------------------------------------------------------------------------
# AI Writing Grader (optional, beta)
# -----------------------------------------------------------------------------
# Server-side API key for the Gemini API. Leave empty to keep the feature
# disabled — the grader page then shows a friendly "not enabled" state.
# NEVER expose this key to the browser (no NEXT_PUBLIC_ prefix).
GEMINI_API_KEY=""

# Optional model override for the writing grader.
GEMINI_MODEL="gemini-3.5-flash"

# -----------------------------------------------------------------------------
# Runtime environment
# -----------------------------------------------------------------------------
# development | production
# Usually set automatically by the platform (Vercel sets this to "production").
NODE_ENV="development"

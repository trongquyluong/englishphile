{
  "name": "englishphile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "admin:promote": "tsx -r tsconfig-paths/register scripts/promote-admin.ts",
    "db:backup": "tsx -r tsconfig-paths/register scripts/db-backup.ts",
    "db:export": "tsx -r tsconfig-paths/register scripts/db-export.ts",
    "db:export:portable": "tsx -r tsconfig-paths/register scripts/db-export-portable.ts",
    "db:import:portable": "tsx -r tsconfig-paths/register scripts/db-import-portable.ts",
    "db:stats": "tsx -r tsconfig-paths/register scripts/db-stats.ts",
    "audit:word-formation-roots": "tsx -r tsconfig-paths/register scripts/audit-word-formation-roots.ts",
    "fix:word-formation-roots": "tsx -r tsconfig-paths/register scripts/fix-word-formation-roots.ts",
    "import:pack": "tsx -r tsconfig-paths/register scripts/import-pack.ts",
    "import:json": "tsx -r tsconfig-paths/register scripts/import-pack.ts"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vercel/analytics": "^2.0.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
